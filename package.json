{
  "name": "bittrack",
  "version": "0.1.2",
  "private": true,
  "description": "Bitcoin accounting desktop app",
  "repository": {
    "type": "git",
    "url": "https://github.com/SimonSomlai/bittracker.git"
  },
  "main": "dist-electron/main.cjs",
  "type": "module",
  "scripts": {
    "predev": "pnpm run dev:cleanup",
    "dev:cleanup": "kill-port 5173 || true",
    "dev": "concurrently \"pnpm run dev:renderer\" \"pnpm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && node scripts/watch-electron.mjs",
    "prices:fetch": "node scripts/fetch-btc-prices.mjs",
    "prices:fetch:fx": "node scripts/fetch-fx-rates.mjs",
    "prices:fetch:diff": "node scripts/fetch-btc-prices.mjs --diff",
    "build:electron": "node scripts/build-electron.mjs",
    "build:renderer": "remix vite:build",
    "build": "pnpm run build:electron && pnpm run build:renderer",
    "dist": "bash scripts/dist.sh",
    "release": "bash scripts/release.sh",
    "start": "pnpm run build && env -u ELECTRON_RUN_AS_NODE electron .",
    "knip": "knip",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "npm_config_target=31.7.7 npm_config_arch=arm64 npm_config_target_arch=arm64 npm_config_disturl=https://electronjs.org/headers npm_config_runtime=electron pnpm rebuild better-sqlite3-multiple-ciphers tiny-secp256k1 argon2 usb node-hid"
  },
  "dependencies": {
    "@ledgerhq/hw-app-btc": "10.4.3",
    "@ledgerhq/hw-transport-node-hid": "6.29.5",
    "@trezor/connect": "9.4.7",
    "argon2": "0.41.1",
    "better-sqlite3-multiple-ciphers": "11.7.0",
    "bip32": "4.0.0",
    "tiny-secp256k1": "2.2.3",
    "tslib": "2.6.0",
    "usb": "2.15.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@radix-ui/react-dialog": "1.1.7",
    "@radix-ui/react-dropdown-menu": "2.1.19",
    "@radix-ui/react-label": "2.1.0",
    "@radix-ui/react-popover": "1.1.18",
    "@radix-ui/react-slot": "1.1.0",
    "@radix-ui/react-toast": "1.2.2",
    "@radix-ui/react-tooltip": "1.2.0",
    "@remix-run/dev": "2.15.1",
    "@remix-run/react": "2.15.1",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "autoprefixer": "10.4.20",
    "bitcoinjs-lib": "6.1.7",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "concurrently": "9.0.1",
    "date-fns": "4.4.0",
    "electron": "31.7.7",
    "electron-builder": "26.0.12",
    "esbuild": "0.24.2",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "exceljs": "4.4.0",
    "globals": "17.7.0",
    "kill-port": "2.0.1",
    "knip": "6.24.0",
    "lucide-react": "0.469.0",
    "postcss": "8.4.49",
    "prettier": "3.9.4",
    "react": "18.3.1",
    "react-day-picker": "10.0.1",
    "react-dom": "18.3.1",
    "recharts": "2.15.0",
    "tailwind-merge": "2.6.0",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2",
    "typescript-eslint": "8.62.1",
    "vite": "5.4.11",
    "vite-tsconfig-paths": "5.1.4",
    "wait-on": "8.0.1"
  },
  "build": {
    "appId": "app.bittrack.desktop",
    "productName": "BitTracker",
    "artifactName": "BitTracker-${version}.${ext}",
    "icon": "resources/icon",
    "directories": {
      "output": "release"
    },
    "files": [
      "build/client/**/*",
      "dist-electron/**/*",
      "package.json",
      "!**/node_modules/usb/libusb/tests/**"
    ],
    "asarUnpack": [
      "**/*.node",
      "**/*.wasm",
      "**/node_modules/tslib/**"
    ],
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 270,
          "y": 60,
          "type": "file",
          "path": "resources/mac/BitTracker Uninstaller.app"
        }
      ]
    },
    "mac": {
      "identity": "Somlai Simon (M6349D88KR)",
      "target": [
        "dmg"
      ],
      "category": "public.app-category.finance",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "resources/entitlements.mac.plist",
      "entitlementsInherit": "resources/entitlements.mac.plist",
      "notarize": true
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    }
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
