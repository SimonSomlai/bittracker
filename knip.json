{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/main/main.ts", "src/main/preload.ts"],
  "project": ["src/renderer/**/*.{ts,tsx}", "src/main/**/*.ts", "scripts/**/*.mjs"],
  "paths": {
    "@/*": ["src/renderer/*"]
  },
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": ["electron-builder"]
}
